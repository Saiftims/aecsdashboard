# ---- HubSpot (server-only, never exposed to the browser) --------------------
HUBSPOT_TOKEN=pat-eu1-xxxxxxxx
HUBSPOT_PORTAL_ID=148349267
# Gate for ALL HubSpot writes (write-back, automation, rollups). Keep false
# until you've reviewed the dashboard against production data.
HUBSPOT_APPLY=false

# ---- Supabase ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only

# ---- Silent Witness case API ---------------------------------------------------
# Base URL of the Silent Witness REST API that exposes GET /cases
# (same API the silentwitness MCP server wraps).
SW_API_BASE_URL=https://api.silentwitness.ai
SILENT_WITNESS_API_KEY=sw_xxx

# ---- PostHog (optional, supplementary product-engagement signals) --------------
POSTHOG_API_KEY=phx_xxx
POSTHOG_HOST=https://us.posthog.com

# ---- Calendly (demo dates - source of truth for when demos run) ----------------
CALENDLY_TOKEN=eyJ...
CALENDLY_ORG=https://api.calendly.com/organizations/xxxx

# ---- Slack -----------------------------------------------------------------------
# Incoming webhook for #sales (handoff + at-risk notifications).
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/xxx

# ---- Cron auth ---------------------------------------------------------------------
# Vercel sends this as "Authorization: Bearer <CRON_SECRET>" on cron requests.
CRON_SECRET=generate-a-long-random-string
